{{ define "login.tmpl" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <style>
    body { margin: 0; min-height: 100vh; display: grid; place-items: center; background: radial-gradient(circle at top, #e6efff, #f8fbff 44%, #eef1f6); font-family: "IBM Plex Sans", "Segoe UI", sans-serif; }
    .card { width: min(420px, calc(100vw - 32px)); background: white; border-radius: 24px; padding: 28px; box-shadow: 0 30px 60px rgba(10, 25, 47, 0.15); }
    form { display: grid; gap: 12px; }
    input, button { padding: 12px 14px; border-radius: 12px; border: 1px solid #d5ddeb; font: inherit; }
    button { background: #0d5bd7; color: white; border: none; font-weight: 700; }
    .error { padding: 10px 12px; border-radius: 12px; background: #fdecec; color: #a43737; margin-bottom: 12px; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Seshat Admin</h1>
    <p>Use the local bootstrap admin account to manage projects, tokens, and ingestion runs.</p>
    {{ if .Error }}<div class="error">{{ .Error }}</div>{{ end }}
    <form method="post" action="/admin/login">
      <input type="text" name="username" placeholder="Username" required>
      <input type="password" name="password" placeholder="Password" required>
      <button type="submit">Sign In</button>
    </form>
  </div>
</body>
</html>
{{ end }}
