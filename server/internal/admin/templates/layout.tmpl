{{ define "layout.tmpl" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <style>
    :root {
      --bg: #f4f7fb;
      --ink: #172033;
      --muted: #60708f;
      --accent: #0455bf;
      --card: #ffffff;
      --line: #d8e0f0;
      --danger: #b42318;
    }
    * { box-sizing: border-box; }
    body { margin: 0; font-family: "IBM Plex Sans", "Segoe UI", sans-serif; color: var(--ink); background: linear-gradient(180deg, #eef4ff 0%, var(--bg) 42%, #edf2f8 100%); }
    header { padding: 20px 28px; background: #0c1830; color: white; display: flex; justify-content: space-between; align-items: center; }
    nav a { color: white; margin-right: 16px; text-decoration: none; font-weight: 600; }
    main { padding: 28px; max-width: 1160px; margin: 0 auto; }
    h1 { margin-top: 0; }
    .grid { display: grid; gap: 20px; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
    .card { background: var(--card); border: 1px solid var(--line); border-radius: 16px; padding: 20px; box-shadow: 0 10px 30px rgba(12,24,48,0.05); }
    table { width: 100%; border-collapse: collapse; }
    th, td { text-align: left; padding: 10px 8px; border-bottom: 1px solid var(--line); vertical-align: top; }
    form { display: grid; gap: 12px; }
    input, textarea, select, button { padding: 10px 12px; border-radius: 10px; border: 1px solid var(--line); font: inherit; }
    button { cursor: pointer; background: var(--accent); color: white; border: none; font-weight: 700; }
    .danger { background: var(--danger); }
    .flash { padding: 14px 16px; border-radius: 12px; background: #e6f4ea; color: #156d2b; margin-bottom: 18px; }
    .muted { color: var(--muted); }
    .badge { display: inline-block; padding: 4px 8px; border-radius: 999px; background: #e8efff; color: var(--accent); font-size: 12px; font-weight: 700; }
  </style>
</head>
<body>
  <header>
    <div>
      <strong>Seshat Admin</strong>
      <div class="muted">Project graph, ingestion, and token operations</div>
    </div>
    <nav>
      <a href="/admin/">Dashboard</a>
      <a href="/admin/projects">Projects</a>
      <a href="/admin/tokens">Tokens</a>
      <a href="/admin/ingestions">Ingestions</a>
      <a href="/admin/audit">Audit</a>
      <a href="/admin/logout">Logout</a>
    </nav>
  </header>
  <main>
    {{ if eq .BodyTemplate "dashboard.tmpl" }}
      {{ template "dashboard.tmpl" . }}
    {{ else if eq .BodyTemplate "projects.tmpl" }}
      {{ template "projects.tmpl" . }}
    {{ else if eq .BodyTemplate "tokens.tmpl" }}
      {{ template "tokens.tmpl" . }}
    {{ else if eq .BodyTemplate "ingestions.tmpl" }}
      {{ template "ingestions.tmpl" . }}
    {{ else if eq .BodyTemplate "audit.tmpl" }}
      {{ template "audit.tmpl" . }}
    {{ end }}
  </main>
</body>
</html>
{{ end }}
